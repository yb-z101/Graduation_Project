# 前端（Vue）忽略文件
frontend/node_modules/  # 前端依赖包（体积大，无需提交）
frontend/dist/          # 前端打包文件
frontend/.env           # 前端环境变量
frontend/*.log          # 日志文件
frontend/.vscode/       # VSCode 配置文件

# 后端（FastAPI）忽略文件
backend/venv/           # 后端虚拟环境
**/__pycache__/         # Python 缓存文件
*.pyc                   # Python 编译文件
*.pyo                   # Python 优化编译文件
backend/graduation.db   # SQLite 数据库文件（本地测试用，不提交）
backend/.env            # 后端环境变量
.idea/                  # IDE 配置文件
.vscode/                # VSCode 配置文件
*.log                   # 日志文件

# Git 通用忽略
.DS_Store
*.swp
*.egg-info/
dist/
build/